# DealLens — Environment Variables
# NEVER commit this file. It is listed in .gitignore.

# ── Gemini — free, no credit card required ────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ── Tavily — 1,000 free searches/month ───────────────────────────────────────
# Get from: https://app.tavily.com
TAVILY_API_KEY=tvly-...

# ── Serper — 2,500 free queries ───────────────────────────────────────────────
# Get from: https://serper.dev
SERPER_API_KEY=your-serper-api-key-here

# ── Crunchbase — 7-day free trial ─────────────────────────────────────────────
# Activate the morning of Day 1 at: https://data.crunchbase.com/docs
# Leave empty if trial not yet activated — pipeline continues without it
CRUNCHBASE_API_KEY=your-crunchbase-api-key-here

# ── Supabase — free tier ──────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# ── Frontend (used by Vite, not the backend) ──────────────────────────────────
VITE_API_URL=http://localhost:8000
